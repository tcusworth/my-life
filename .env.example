# PocketBase URL (your VPS instance — must be HTTPS in production)
NEXT_PUBLIC_POCKETBASE_URL=https://pb.example.com

# Canonical frontend URL (Vercel or self-hosted)
NEXT_PUBLIC_APP_URL=https://app.example.com

# AI inbox processing (server-side only — never expose to client)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Seed script only (npm run seed:areas) ---
