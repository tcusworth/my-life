# PocketBase URL (your VPS instance — must be HTTPS in production)
NEXT_PUBLIC_POCKETBASE_URL=https://pb.example.com

# Canonical frontend URL (Vercel or self-hosted)
NEXT_PUBLIC_APP_URL=https://app.example.com

# AI inbox processing (server-side only — never expose to client)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# PocketBase admin (server-side sync API only — never expose to client)
POCKETBASE_ADMIN_EMAIL=
POCKETBASE_ADMIN_PASSWORD=

# Show soft-deleted calendar events on /calendar (optional)
# NEXT_PUBLIC_SYNC_DEBUG=true
# POCKETBASE_URL=https://pb.example.com
# SEED_USER_EMAIL=you@example.com
# SEED_USER_PASSWORD=
